# MapleMed — Mailing list (Brevo) integration
#
# Copy this file to ".env.local" for local development:
#   cp .env.example .env.local
#
# These variables are read ONLY on the server (in the /api/subscribe route).
# They are never exposed to the browser, so do NOT prefix them with NEXT_PUBLIC_.

# Your Brevo (formerly Sendinblue) API v3 key.
# Create one at: https://app.brevo.com/settings/keys/api
BREVO_API_KEY=

# The numeric ID of the Brevo contact list new subscribers are added to.
# Find it under: Brevo dashboard -> Contacts -> Lists (the # column).
BREVO_LIST_ID=

# NOTE:
# If either variable is missing, the API route returns a MOCK success response
# in development so you can build the UI without a live Brevo account.
# See src/app/api/subscribe/route.ts for details.
